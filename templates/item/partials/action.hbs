{{!-- Editor da LISTA de ações do item. Cada ação tem rolagem, modo de alvo,
      área/alcance, dano e condições próprios.
      Espera: actions (enriquecidas), attackAttrs, defenseAttrs, damageTypes. --}}
<div class="lig-actions-editor">
  <div class="lig-section-title">
    Ações
    <button type="button" class="lig-mini-btn" data-action="addAction">+ ação</button>
  </div>
  <p class="lig-hint">Cada ação é uma rolagem/efeito independente (ex.: um golpe corpo-a-corpo, uma onda em área, um toque que aplica condição). Mostra um botão 🎲 por ação na ficha.</p>

  {{#each actions as |act i|}}
  <div class="lig-action-block">
    <div class="lig-action-head">
      <input type="text" name="system.actions.{{i}}.label" value="{{act.label}}" placeholder="Nome da ação" class="lig-action-label"/>
      <button type="button" class="lig-mini-btn danger" data-action="removeAction" data-index="{{i}}" title="Remover ação">✕</button>
    </div>

    <label class="lig-inline-check">
      <input type="checkbox" name="system.actions.{{i}}.canRoll" {{checked act.canRoll}}/>
      Faz rolagem de ataque (contra a defesa do alvo)
    </label>

    <label class="lig-inline-check">
      <input type="checkbox" name="system.actions.{{i}}.vsDifficulty" {{checked act.vsDifficulty}}/>
      Faz rolagem contra dificuldade fixa (CD)
    </label>
    {{#if act.vsDifficulty}}
    <div class="lig-item-row">
      <label>Dificuldade fixa (CD)
        <input type="number" name="system.actions.{{i}}.fixedDifficulty" value="{{act.fixedDifficulty}}" min="0"/>
      </label>
      <label>Somar atributo do alvo à CD
        <select name="system.actions.{{i}}.difficultyAttr">{{selectOptions ../difficultyAttrChoices selected=act.difficultyAttr}}</select>
      </label>
    </div>
    <p class="lig-hint">A CD efetiva contra cada alvo = CD fixa + o atributo escolhido do alvo. Use "Nenhum" para uma CD fixa pura. (Sem alvo, só a CD fixa vale.)</p>
    {{/if}}
    <p class="lig-hint">Se ataque e CD estiverem marcados juntos, a ação precisa superar a defesa do alvo <em>e</em> a CD. Marque só um para usar apenas aquele.</p>

    <div class="lig-item-row">
      <label>Atributo da rolagem
        <select name="system.actions.{{i}}.rollAttr">{{selectOptions ../attackAttrs selected=act.rollAttr}}</select>
      </label>
      <label>Bônus
        <input type="number" name="system.actions.{{i}}.rollBonus" value="{{act.rollBonus}}"/>
      </label>
      <label>Dados extra
        <input type="number" name="system.actions.{{i}}.rollDice" value="{{act.rollDice}}" min="0"/>
      </label>
    </div>

    <div class="lig-item-row">
      <label>Alvo
        <select name="system.actions.{{i}}.targetMode">
          <option value="none" {{#if (eq act.targetMode "none")}}selected{{/if}}>Nenhum</option>
          <option value="self" {{#if (eq act.targetMode "self")}}selected{{/if}}>O próprio personagem</option>
          <option value="target" {{#if (eq act.targetMode "target")}}selected{{/if}}>Alvo(s) mirado(s)</option>
          <option value="area" {{#if (eq act.targetMode "area")}}selected{{/if}}>Área (afeta quem está nela)</option>
          <option value="aura" {{#if (eq act.targetMode "aura")}}selected{{/if}}>Aura (afeta os outros, não você)</option>
        </select>
      </label>
      <label>Alcance (m)
        <input type="number" name="system.actions.{{i}}.range" value="{{act.range}}" min="0" step="0.5"/>
      </label>
      {{#if (or (eq act.targetMode "area") (eq act.targetMode "aura"))}}
      <label>Raio da área (m)
        <input type="number" name="system.actions.{{i}}.area" value="{{act.area}}" min="0" step="0.5"/>
      </label>
      {{/if}}
    </div>

    {{#if (or (eq act.targetMode "area") (eq act.targetMode "aura"))}}
    <label class="lig-inline-check">
      <input type="checkbox" name="system.actions.{{i}}.includeSelf" {{checked act.includeSelf}}/>
      {{#if (eq act.targetMode "aura")}}Exceção: incluir você também na aura{{else}}Exceção: incluir você mesmo se estiver fora da área{{/if}}
    </label>
    {{/if}}

    {{#if (or (eq act.targetMode "target") (eq act.targetMode "area") (eq act.targetMode "aura"))}}
    <div class="lig-item-row">
      <label>Defesa do alvo
        <select name="system.actions.{{i}}.defenseAttr">{{selectOptions ../defenseAttrs selected=act.defenseAttr}}</select>
      </label>
      <label>Defesa alternativa (usa a melhor)
        <select name="system.actions.{{i}}.defenseAttr2">
          <option value="" {{#unless act.defenseAttr2}}selected{{/unless}}>— nenhuma —</option>
          {{selectOptions ../defenseAttrs selected=act.defenseAttr2}}
        </select>
      </label>
    </div>
    {{/if}}

    <div class="lig-item-row">
      <label>Dano (ex: 1d6+2)
        <input type="text" name="system.actions.{{i}}.damage" value="{{act.damage}}" placeholder="vazio = sem dano"/>
      </label>
      <label>Recurso afetado
        <select name="system.actions.{{i}}.damageResource">
          <option value="hp" {{#if (eq act.damageResource "hp")}}selected{{/if}}>Vida (PV)</option>
          <option value="mp" {{#if (eq act.damageResource "mp")}}selected{{/if}}>Mana (PM)</option>
          <option value="heroic" {{#if (eq act.damageResource "heroic")}}selected{{/if}}>Pontos Heroicos</option>
        </select>
      </label>
      {{#if (eq act.damageResource "hp")}}
      <label>Tipo de dano
        <select name="system.actions.{{i}}.damageType">
          <option value="" {{#unless act.damageType}}selected{{/unless}}>—</option>
          {{selectOptions ../damageTypes selected=act.damageType}}
        </select>
      </label>
      {{/if}}
    </div>

    <label class="lig-inline-check">
      <input type="checkbox" name="system.actions.{{i}}.scalingDamage" {{checked act.scalingDamage}}/>
      Dano escalonado (+1 por 2 pontos acima da defesa)
    </label>

    <div class="lig-item-row lig-action-costs">
      <label>Custo PM
        <input type="number" name="system.actions.{{i}}.costMp" value="{{act.costMp}}" min="0"/>
      </label>
      <label>Custo PV
        <input type="number" name="system.actions.{{i}}.costHp" value="{{act.costHp}}" min="0"/>
      </label>
      <label>Custo PH
        <input type="number" name="system.actions.{{i}}.costHeroic" value="{{act.costHeroic}}" min="0"/>
      </label>
    </div>

    <div class="lig-applies-fx-editor">
      <div class="lig-subtitle">
        Efeitos aplicados ao alvo (buff / debuff / condição)
        <button type="button" class="lig-mini-btn" data-action="addAppliesEffect" data-action-index="{{i}}">+ efeito</button>
      </div>
      {{#each act.appliesEffects as |fx fi|}}
      <div class="lig-applies-fx-row">
        <div class="lig-item-row">
          <input type="text" name="system.actions.{{i}}.appliesEffects.{{fi}}.label" value="{{fx.label}}" placeholder="Nome do efeito" class="lig-fx-name"/>
          <button type="button" class="lig-mini-btn danger" data-action="removeAppliesEffect" data-action-index="{{i}}" data-index="{{fi}}" title="Remover">✕</button>
        </div>
        <div class="lig-item-row">
          <label>Modificador
            <select name="system.actions.{{i}}.appliesEffects.{{fi}}.fxType">
              <option value="bonus" {{#if (eq fx.fxType "bonus")}}selected{{/if}}>Bônus</option>
              <option value="dice" {{#if (eq fx.fxType "dice")}}selected{{/if}}>Dado de melhoria</option>
              <option value="stat" {{#if (eq fx.fxType "stat")}}selected{{/if}}>Modificar valor</option>
              <option value="set" {{#if (eq fx.fxType "set")}}selected{{/if}}>Definir valor</option>
              <option value="damage" {{#if (eq fx.fxType "damage")}}selected{{/if}}>Bônus de dano</option>
              <option value="rd" {{#if (eq fx.fxType "rd")}}selected{{/if}}>Redução de dano</option>
              <option value="reroll1" {{#if (eq fx.fxType "reroll1")}}selected{{/if}}>Rerrolar dados que caem 1</option>
              <option value="reroll6" {{#if (eq fx.fxType "reroll6")}}selected{{/if}}>Rerrolar dados que caem 6</option>
              <option value="crit" {{#if (eq fx.fxType "crit")}}selected{{/if}}>Crítico aprimorado</option>
              <option value="fumble" {{#if (eq fx.fxType "fumble")}}selected{{/if}}>Falha crítica piorada</option>
              <option value="condition" {{#if (eq fx.fxType "condition")}}selected{{/if}}>Condição</option>
            </select>
          </label>
          <label>Alvo
            <select name="system.actions.{{i}}.appliesEffects.{{fi}}.fxTarget">
              {{selectOptions fx.targetChoices selected=fx.fxTarget}}
            </select>
          </label>
          {{#unless (eq fx.fxType "condition")}}
          <label>{{#if (or (eq fx.fxType "reroll1") (eq fx.fxType "reroll6"))}}Qtd. dados{{else}}Valor{{/if}}
            <input type="number" name="system.actions.{{i}}.appliesEffects.{{fi}}.fxValue" value="{{fx.fxValue}}"/>
          </label>
          {{/unless}}
          {{#if (or (eq fx.fxType "reroll1") (eq fx.fxType "reroll6"))}}
          <label class="lig-inline-check" title="Rerrolar TODOS os dados que caírem nesse valor">
            <input type="checkbox" name="system.actions.{{i}}.appliesEffects.{{fi}}.fxAll" {{checked fx.fxAll}}/>
            Todos
          </label>
          {{/if}}
        </div>
        <div class="lig-item-row">
          <label>Duração
            <select name="system.actions.{{i}}.appliesEffects.{{fi}}.durationMode">
              <option value="scene" {{#if (eq fx.durationMode "scene")}}selected{{/if}}>Até o fim da cena</option>
              <option value="rounds" {{#if (eq fx.durationMode "rounds")}}selected{{/if}}>Em rodadas</option>
            </select>
          </label>
          {{#if (eq fx.durationMode "rounds")}}
          <label>Rodadas
            <input type="number" name="system.actions.{{i}}.appliesEffects.{{fi}}.durationRounds" value="{{fx.durationRounds}}" min="0"/>
          </label>
          {{/if}}
        </div>
        <div class="lig-item-row">
          <label class="lig-inline-check">
            <input type="checkbox" name="system.actions.{{i}}.appliesEffects.{{fi}}.resist" {{checked fx.resist}}/>
            Resistência por rodada
          </label>
          {{#if fx.resist}}
          <label>Atributo
            <select name="system.actions.{{i}}.appliesEffects.{{fi}}.resistAttr">
              <option value="forca" {{#if (eq fx.resistAttr "forca")}}selected{{/if}}>Força</option>
              <option value="agilidade" {{#if (eq fx.resistAttr "agilidade")}}selected{{/if}}>Agilidade</option>
              <option value="vigor" {{#if (eq fx.resistAttr "vigor")}}selected{{/if}}>Vigor</option>
              <option value="mente" {{#if (eq fx.resistAttr "mente")}}selected{{/if}}>Mente</option>
              <option value="percepcao" {{#if (eq fx.resistAttr "percepcao")}}selected{{/if}}>Percepção</option>
            </select>
          </label>
          <label class="lig-inline-check">
            <input type="checkbox" name="system.actions.{{i}}.appliesEffects.{{fi}}.resistVsCast" {{checked fx.resistVsCast}}/>
            CD = rolagem da conjuração
          </label>
          {{#unless fx.resistVsCast}}
          <label>CD fixa
            <input type="number" name="system.actions.{{i}}.appliesEffects.{{fi}}.resistDc" value="{{fx.resistDc}}" min="0"/>
          </label>
          {{/unless}}
          {{/if}}
        </div>
        <div class="lig-item-row">
          <label>Dano contínuo/rodada
            <input type="number" name="system.actions.{{i}}.appliesEffects.{{fi}}.tickAmount" value="{{fx.tickAmount}}" min="0"/>
          </label>
          <label>Tipo
            <select name="system.actions.{{i}}.appliesEffects.{{fi}}.tickType">
              <option value="" {{#unless fx.tickType}}selected{{/unless}}>—</option>
              {{selectOptions ../../damageTypes selected=fx.tickType}}
            </select>
          </label>
          <label>Recurso
            <select name="system.actions.{{i}}.appliesEffects.{{fi}}.tickResource">
              <option value="hp" {{#if (eq fx.tickResource "hp")}}selected{{/if}}>PV</option>
              <option value="mp" {{#if (eq fx.tickResource "mp")}}selected{{/if}}>PM</option>
              <option value="heroic" {{#if (eq fx.tickResource "heroic")}}selected{{/if}}>PH</option>
            </select>
          </label>
        </div>
      </div>
      {{/each}}
    </div>

    {{!-- Macro executada ao rodar a ação --}}
    <div class="lig-macro-section">
      <div class="lig-subtitle">Macro ao executar</div>
      {{#if act.macroUuid}}
      <div class="lig-macro-bound {{#unless act.macroEnabled}}off{{/unless}}">
        <button type="button" class="lig-mini-btn" data-action="toggleMacro" data-action-index="{{i}}" title="Ativar/desativar">{{#if act.macroEnabled}}●{{else}}○{{/if}}</button>
        <span class="lig-macro-name" data-action="openMacro" data-action-index="{{i}}" title="Abrir macro">🎬 {{act.macroName}}</span>
        <button type="button" class="lig-mini-btn danger" data-action="removeMacro" data-action-index="{{i}}" title="Remover macro">✕</button>
      </div>
      {{else}}
      <div class="lig-macro-drop" data-action-index="{{i}}">
        Arraste uma macro aqui
      </div>
      {{/if}}
    </div>
  </div>
  {{/each}}
  {{#unless actions.length}}
  <div class="lig-empty">Nenhuma ação. Clique em "+ ação" para criar a primeira (ataque, área, etc.).</div>
  {{/unless}}
</div>
